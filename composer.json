{
    "name": "software-compass/software-compass",
    "description": "An open-source, self-hosted Enterprise Architecture repository for components, interfaces, dependencies and customer journeys.",
    "type": "project",
    "license": "AGPL-3.0-only",
    "require": {
        "php": "^8.4",
        "tempest/framework": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3.10",
        "symfony/var-dumper": "^7.3.3",
        "carthage-software/mago": "1.0.0-beta.13",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "App\\PHPStan\\": "phpstan/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php ./vendor/bin/tempest install framework -f",
            "@php ./tempest discovery:generate --no-interaction",
            "@php ./tempest key:generate"
        ],
        "post-autoload-dump": [
            "@php ./vendor/bin/tempest discovery:generate --no-interaction"
        ],
        "phpunit": "vendor/bin/phpunit --display-warnings --display-skipped --display-deprecations --display-errors --display-notices",
        "test": "@phpunit",
        "test:docker": "docker compose exec app composer test",
        "precommit:test": "docker compose exec -T app composer test",
        "hooks:install": "git config core.hooksPath .githooks",
        "qa:docker": "docker compose exec app composer qa",
        "fmt": "vendor/bin/mago fmt",
        "lint": "vendor/bin/mago lint --fix --format-after-fix",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "migrations:hashes": "php scripts/update-migration-hashes.php",
        "qa": [
            "composer fmt",
            "composer phpunit",
            "composer lint",
            "composer analyse"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "carthage-software/mago": true
        }
    }
}
