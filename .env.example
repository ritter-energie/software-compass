# Possible values: local, staging, production, ci, testing, other
ENVIRONMENT=local

# The base URI that's used for all generated URIs
BASE_URI=http://localhost:8080

# Setting to `false` force-disable internal caches.
INTERNAL_CACHES=true

# Enable or disable discovery cache. Can be `true`, `partial` or `false`.
DISCOVERY_CACHE=partial

# Overwrite default log paths (null = default)
DEBUG_LOG_PATH=null
SERVER_LOG_PATH=null

# MariaDB connection (see COPILOT_IMPLEMENTATION_BRIEFING.md, section 5)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=software_compass
DB_USERNAME=software_compass
DB_PASSWORD=change-me

# Local Docker convenience: run Tempest discovery and pending migrations when
# the app container starts. Set AUTO_MIGRATE=false if you want manual control.
AUTO_DISCOVERY_GENERATE=true
AUTO_MIGRATE=true

